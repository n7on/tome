Resources
| where type == "microsoft.network/networksecuritygroups"
| where array_length(properties.networkInterfaces) == 0
| where array_length(properties.subnets) == 0
| where isnull(tags.ArchivedUntil) or todatetime(tostring(tags.ArchivedUntil)) <= now()
| project name, resourceGroup, location, kind, subscriptionId
