Resources
| where type == "microsoft.network/networkinterfaces"
| where isnull(properties.virtualMachine.id)
| where not(tostring(properties.ipConfigurations) has "privateLinkConnectionProperties")
| where isnull(tags.ArchivedUntil) or todatetime(tostring(tags.ArchivedUntil)) <= now()
| project name, resourceGroup, location, kind, subscriptionId
