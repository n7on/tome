#!/usr/bin/env bash
# Wrapper to run grim commands
# Usage: grim <command> [args...]
#        grim nmap scan quick localhost

_GRIM_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
source "$_GRIM_DIR/init.bash"

# Built-in: grim completion bash
if [[ "${1:-}" == "completion" && "${2:-}" == "bash" ]]; then
    completion_bash
    exit $?
fi

if [[ "${1:-}" == "completion" && "${2:-}" == "zsh" ]]; then
    completion_zsh
    exit $?
fi

# Collect non-flag leading words to form the command name
parts=()
for arg in "$@"; do
    [[ "$arg" == -* ]] && break
    parts+=("$arg")
done

# Try longest match first (nmap scan quick → nmap_scan_quick)
cmd="" cmd_len=0
for ((len=${#parts[@]}; len>=1; len--)); do
    candidate="${parts[0]}"
    for ((i=1; i<len; i++)); do
        candidate="${candidate}_${parts[$i]}"
    done
    if declare -F "$candidate" &>/dev/null; then
        cmd="$candidate"
        cmd_len=$len
        break
    fi
done

if [[ -z "$cmd" ]]; then
    echo "Unknown command: ${parts[*]}" >&2
    echo "Run 'grim grim command list' for available commands" >&2
    exit 1
fi

"$cmd" "${@:$((cmd_len + 1))}"
