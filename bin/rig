#!/usr/bin/env bash
# Wrapper to run tome commands
# Usage: tome <command> [args...]
#        tome nmap scan quick localhost

_RIG_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
_RIG_PYTHON="$HOME/.rig/.venv/bin/python3"

# Source all _* framework dirs
_rig_source_framework() {
    local dir file
    for dir in "$_RIG_DIR/src"/_*/; do
        for file in "$dir"*.bash; do
            [[ -f "$file" ]] && source "$file"
        done
    done
}

# Built-in: rig __complete <prefix> <prev> <cur>
if [[ "${1:-}" == "__complete" ]]; then
    _prefix="${2:-}"
    _prev="${3:-}"
    _cur="${4:-}"

    # Top-level: list all available namespaces
    if [[ -z "$_prefix" ]]; then
        for _dir in "$_RIG_DIR/src"/*/; do
            _base="$(basename "$_dir")"
            [[ "$_base" == _* ]] && continue
            echo "$_base"
        done
        for _repo in "$HOME/.rig/pack"/*/; do
            [[ -d "$_repo/src" ]] || continue
            for _dir in "$_repo/src"/*/; do
                _base="$(basename "$_dir")"
                [[ "$_base" == _* ]] && continue
                echo "$_base"
            done
        done | sort -u
        exit 0
    fi

    _rig_source_framework

    # Source the relevant namespace module (and its deps)
    _namespace="${_prefix%%_*}"
    _require_module "$_namespace" 2>/dev/null || true

    # Prev is a flag: return value or dynamic completions
    if [[ "$_prev" == --* ]]; then
        if [[ -v _COMPLETER_FUNCS["${_prefix}:${_prev}"] ]]; then
            "${_COMPLETER_FUNCS[${_prefix}:${_prev}]}" "$_cur"
        elif [[ -v _COMPLETERS["${_prefix}:${_prev}"] ]]; then
            echo "${_COMPLETERS[${_prefix}:${_prev}]}"
        fi
        exit 0
    fi

    # Prefix is a known command: return its flags
    if declare -F "$_prefix" &>/dev/null; then
        for _key in "${!_PARAMS[@]}"; do
            [[ "$_key" == "${_prefix}:"* ]] || continue
            echo "--${_key##*:}"
        done
        exit 0
    fi

    # Return next subcommand words for this prefix
    for _key in "${!_PARAMS[@]}"; do
        _cmd="${_key%%:*}"
        [[ "$_cmd" == _* ]] && continue
        [[ "$_cmd" == "${_prefix}_"* ]] || continue
        _rest="${_cmd#${_prefix}_}"
        echo "${_rest%%_*}"
    done | sort -u

    exit 0
fi

_rig_source_framework

# Collect non-flag leading words to form the command name
parts=()
for arg in "$@"; do
    [[ "$arg" == -* ]] && break
    parts+=("$arg")
done

if [[ ${#parts[@]} -eq 0 ]]; then
    echo "Usage: tome <command> [args...]" >&2
    echo "Run 'rig command list' for available commands" >&2
    exit 1
fi

# Source the relevant namespace module (and its deps)
_require_module "${parts[0]}" || exit 1

# Try longest match first (nmap scan quick → nmap_scan_quick)
cmd="" cmd_len=0
for ((len=${#parts[@]}; len>=1; len--)); do
    candidate="${parts[0]}"
    for ((i=1; i<len; i++)); do
        candidate="${candidate}_${parts[$i]}"
    done
    if declare -F "$candidate" &>/dev/null; then
        cmd="$candidate"
        cmd_len=$len
        break
    fi
done

if [[ -z "$cmd" ]]; then
    echo "Unknown command: ${parts[*]}" >&2
    echo "Run 'rig command list' for available commands" >&2
    exit 1
fi

"$cmd" "${@:$((cmd_len + 1))}"
